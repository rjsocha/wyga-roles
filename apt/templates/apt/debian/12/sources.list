{% endif %}
{% else %}
deb http://ftp.{{ apt.mirror }}.debian.org/debian bookworm main{% if apt.contrib %} contrib{% endif %}{% if apt.nonfree %} non-free{% endif %}{% if apt.nonfreefirmware %} non-free-firmware{% endif %}


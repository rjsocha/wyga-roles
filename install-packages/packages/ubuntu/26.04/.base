prerequisite:
  - apt-transport-https
  - ca-certificates
  - gawk
require:
  - apt-utils
  - bash-completion
  - bzip2
  - curl
  - distro-info-data
  - dracut
  - dnsutils
  - dosfstools
  - fdisk
  - haveged
  - iproute2
  - less
  - lsb-release
  - lsof
  - mc
  - mtr-tiny
  - openssh-client
  - openssh-server
  - openssh-sftp-server
  - python3-apt
  - python-apt-common
  - rsync
  - screen
  - sudo
  - sysstat
  - systemd-resolved
  - time
  - tmux
  - unzip
  - vim
  - wget
  - xz-utils
  - zstd
  - tpm-udev
  - apparmor
  - perl-modules
  - systemd-timesyncd
  - psmisc
  - netcat-openbsd
  - btrfs-progs
  - exfatprogs
  - git
  - iputils-ping
purge:
  - mawk
  - netcat-traditional
  - inetutils-ping

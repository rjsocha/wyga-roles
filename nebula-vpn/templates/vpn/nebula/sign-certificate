#!/usr/bin/env bash
set -eufo pipefail
IFS=$'\t\n'

nebula-cert sign \
            -ca-crt "{{ instance.ca.crt }}" \
            -ca-key "{{ instance.ca.key }}" \
            -in-pub "{{ playbook_dir }}/vpn/inbox/{{ instance.name }}-{{ instance.hostname }}.pub" \
            -out-crt "{{ playbook_dir }}/vpn/inbox/{{ instance.name }}-{{ instance.hostname }}.crt" \
            -name "{{ instance.fqdn }}" \
{% if instance.network.subnets | length > 0 %}
            -unsafe-networks "{{ ','.join(instance.network.subnets) }}" \
{% endif %}
            -ip "{{ ','.join(instance.ip) }}" \
            -version "{{ instance.ca.version }}"
